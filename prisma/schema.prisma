generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String   @unique
  name        String?
  image       String?
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks        Task[]
  schedules    Schedule[]
  activityLogs ActivityLog[]
  notes        Note[]
  expenses     Expense[]
  waterIntakes WaterIntake[]
}

model Task {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  userId           String      @db.ObjectId
  title            String
  description      String?
  startDate        DateTime?
  deadline         DateTime?
  status           TaskStatus  @default(TODO)
  tags             String[]
  
  subtasks         Subtask[]

  parentId         String?     @db.ObjectId
  parentTask       Task?       @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subTasksRelation Task[]      @relation("TaskHierarchy")

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityLogs     ActivityLog[]
}

type Subtask {
  id        String
  title     String
  completed Boolean @default(false)
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

model Schedule {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  title        String
  startTime    DateTime
  endTime      DateTime
  isRoutine    Boolean  @default(false)
  routineType  String   @default("WEEKLY") // "WEEKLY", "MONTHLY", "YEARLY"
  routineDays  Int[]    // Weekly: 0-6 (Sun-Sat), Monthly: [day], Yearly: [day]
  routineMonth Int?     // Yearly: 1-12
  isAllDay     Boolean  @default(false)
  
  cost         Float?
  isFixedCost  Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  taskId        String?  @db.ObjectId
  
  startTime     DateTime
  endTime       DateTime?
  durationMins  Int?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model Note {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  content   String
  type      String   // 'SPEC' or 'SANDBOX'
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amount    Float
  category  String   // 'COFFEE', 'WATER', 'TRANSPORT', 'OTHER'
  title     String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaterIntake {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amountMl  Int
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
